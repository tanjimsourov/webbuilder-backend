# =============================================================================
# SMC Web Builder - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=generate-a-64-character-random-string
DJANGO_ALLOWED_HOSTS=webbuilderapi.husmerk.com
DJANGO_CORS_ALLOWED_ORIGINS=https://smc-web-builder.husmerk.com,https://admin-web-builder.husmerk.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://smc-web-builder.husmerk.com,https://admin-web-builder.husmerk.com
DJANGO_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL (production)
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=smc_web_builder
DJANGO_DB_USER=smc_web_builder
DJANGO_DB_PASSWORD=replace-with-strong-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

# -----------------------------------------------------------------------------
# Security Settings (Production)
# -----------------------------------------------------------------------------
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SESSION_COOKIE_SAMESITE=Strict
DJANGO_CSRF_COOKIE_SAMESITE=Strict

# -----------------------------------------------------------------------------
# API Rate Limiting
# -----------------------------------------------------------------------------
# DJANGO_THROTTLE_ANON=100/hour
# DJANGO_THROTTLE_USER=1000/hour
# DJANGO_THROTTLE_BURST=60/minute
# DJANGO_THROTTLE_PUBLIC_FORM=30/hour
# DJANGO_THROTTLE_PUBLIC_COMMENT=20/hour
# DJANGO_THROTTLE_PUBLIC_CHECKOUT=60/hour
# DJANGO_THROTTLE_WEBHOOK=1000/minute

# -----------------------------------------------------------------------------
# Database Connection Pooling (Production)
# -----------------------------------------------------------------------------
# DJANGO_DB_CONN_MAX_AGE=60

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# DJANGO_LOG_FORMAT=json
# DJANGO_DJANGO_LOG_LEVEL=WARNING

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
# DJANGO_MAX_UPLOAD_SIZE=10485760
# DJANGO_MAX_IMAGE_SIZE=5242880
# DJANGO_MAX_VIDEO_SIZE=104857600
# DJANGO_MAX_DOCUMENT_SIZE=20971520

# -----------------------------------------------------------------------------
# Stripe Payment Integration (Required for e-commerce)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Google Search Console Integration (Optional for SEO)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/seo/gsc/callback/

# -----------------------------------------------------------------------------
# Namecheap Domain Registration (Optional)
# -----------------------------------------------------------------------------
# NAMECHEAP_API_USER=your-username
# NAMECHEAP_API_KEY=your-api-key
# NAMECHEAP_USERNAME=your-username
# NAMECHEAP_CLIENT_IP=your-whitelisted-ip

# -----------------------------------------------------------------------------
# AI Studio (Optional)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# LibreCrawl Companion Service (Optional deep technical SEO crawler)
# -----------------------------------------------------------------------------
# LIBRECRAWL_ENABLED=true
# LIBRECRAWL_HOST=127.0.0.1
# LIBRECRAWL_PORT=5055
# LIBRECRAWL_PUBLIC_URL=http://127.0.0.1:5055
# LIBRECRAWL_LOCAL_MODE=true
# LIBRECRAWL_SECRET_KEY=change-me-if-you-expose-librecrawl

# -----------------------------------------------------------------------------
# SerpBear Companion Service (Optional keyword rank tracker)
# -----------------------------------------------------------------------------
# SERPBEAR_ENABLED=true
# SERPBEAR_HOST=127.0.0.1
# SERPBEAR_PORT=5060
# SERPBEAR_PUBLIC_URL=http://127.0.0.1:5060

# -----------------------------------------------------------------------------
# Umami Companion Service (Optional product analytics)
# -----------------------------------------------------------------------------
# UMAMI_ENABLED=true
# UMAMI_HOST=127.0.0.1
# UMAMI_PORT=5070
# UMAMI_PUBLIC_URL=http://127.0.0.1:5070
# UMAMI_DATABASE_URL=postgresql://username:password@localhost:5432/umami

# -----------------------------------------------------------------------------
# Payload CMS Companion (Optional headless CMS stack)
# -----------------------------------------------------------------------------
# PAYLOAD_CMS_ENABLED=true
# PAYLOAD_CMS_HOST=127.0.0.1
# PAYLOAD_CMS_PORT=5080
# PAYLOAD_CMS_PUBLIC_URL=http://127.0.0.1:5080
# PAYLOAD_CMS_DATABASE_URL=mongodb://127.0.0.1:27017/payload-cms
# PAYLOAD_CMS_SECRET=replace-with-a-strong-secret
# PAYLOAD_CMS_PREVIEW_SECRET=replace-with-a-preview-secret
# PAYLOAD_CMS_CRON_SECRET=replace-with-a-cron-secret

# -----------------------------------------------------------------------------
# Payload Ecommerce Companion (Optional advanced commerce stack)
# -----------------------------------------------------------------------------
# PAYLOAD_ECOMMERCE_ENABLED=true
# PAYLOAD_ECOMMERCE_HOST=127.0.0.1
# PAYLOAD_ECOMMERCE_PORT=5085
# PAYLOAD_ECOMMERCE_PUBLIC_URL=http://127.0.0.1:5085
# PAYLOAD_ECOMMERCE_DATABASE_URL=mongodb://127.0.0.1:27017/payload-commerce
# PAYLOAD_ECOMMERCE_SECRET=replace-with-a-strong-secret
# PAYLOAD_ECOMMERCE_PREVIEW_SECRET=replace-with-a-preview-secret
# PAYLOAD_ECOMMERCE_STRIPE_SECRET_KEY=sk_test_...
# PAYLOAD_ECOMMERCE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# PAYLOAD_ECOMMERCE_STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Email Configuration (Optional for notifications)
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@smcwebbuilder.com

# -----------------------------------------------------------------------------
# Media Storage (Optional - S3/CDN)
# -----------------------------------------------------------------------------
# DJANGO_USE_S3_STORAGE=true
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com

# -----------------------------------------------------------------------------
# Sentry APM / Error Tracking (Production)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your-key@sentry.io/your-project
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
