# =============================================================================
# SMC Web Builder Backend - Sample Environment File
# =============================================================================
# This file is sample-only. Copy it to `.env` for local development.
# Never commit a real `.env` file with active secrets.

# -----------------------------------------------------------------------------
# Local Development Defaults
# -----------------------------------------------------------------------------
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-secret-key-please-change-before-production-1234567890
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_PLATFORM_FRONTEND_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# -----------------------------------------------------------------------------
# Security / Session / Proxy
# -----------------------------------------------------------------------------
DJANGO_USE_X_FORWARDED_HOST=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_X_FRAME_OPTIONS=SAMEORIGIN
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SESSION_COOKIE_AGE=1209600

# -----------------------------------------------------------------------------
# Database (SQLite for local development)
# -----------------------------------------------------------------------------
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=
DJANGO_DB_PORT=
DJANGO_DB_CONN_MAX_AGE=0

# -----------------------------------------------------------------------------
# Cache (optional for local; required in production)
# -----------------------------------------------------------------------------
DJANGO_CACHE_URL=
DJANGO_CACHE_DEFAULT_TIMEOUT=300

# -----------------------------------------------------------------------------
# Celery (background workers)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# -----------------------------------------------------------------------------
# Auth and metrics gates
# -----------------------------------------------------------------------------
DJANGO_AUTH_BOOTSTRAP_ENABLED=true
DJANGO_AUTH_BOOTSTRAP_TOKEN=dev-bootstrap-token-not-for-production-123456
DJANGO_AUTH_MAGIC_LOGIN_ENABLED=true
DJANGO_ENABLE_ADMIN=true
DJANGO_METRICS_AUTH_TOKEN=dev-metrics-token-not-for-production-123456
DJANGO_METRICS_ALLOW_QUERY_TOKEN=true
DJANGO_PAYMENT_WEBHOOK_IDEMPOTENCY_TTL_SECONDS=604800
DJANGO_REDIRECT_ALLOWED_EXTERNAL_HOSTS=
DJANGO_ALLOW_PRIVATE_WEBHOOK_TARGETS=true

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=noreply@smcwebbuilder.local
DJANGO_SERVER_EMAIL=noreply@smcwebbuilder.local

# -----------------------------------------------------------------------------
# Payments / AI / Domain providers (optional)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=
MEILISEARCH_SETTINGS_SYNC_INTERVAL_SECONDS=300
NEXTJS_SITE_RUNTIME_BASE_URL=
NEXTJS_REVALIDATE_SECRET=
NEXTJS_REVALIDATE_ENDPOINT=/api/revalidate
NEXTJS_REVALIDATE_TIMEOUT_SECONDS=10
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=

# -----------------------------------------------------------------------------
# Companion services (disabled by default)
# -----------------------------------------------------------------------------
LIBRECRAWL_ENABLED=false
LIBRECRAWL_HOST=127.0.0.1
LIBRECRAWL_PORT=5055
LIBRECRAWL_PUBLIC_URL=http://127.0.0.1:5055
LIBRECRAWL_LOCAL_MODE=true
LIBRECRAWL_SECRET_KEY=

SERPBEAR_ENABLED=false
SERPBEAR_HOST=127.0.0.1
SERPBEAR_PORT=5060
SERPBEAR_PUBLIC_URL=http://127.0.0.1:5060

UMAMI_ENABLED=false
UMAMI_HOST=127.0.0.1
UMAMI_PORT=5070
UMAMI_PUBLIC_URL=http://127.0.0.1:5070

PAYLOAD_CMS_ENABLED=false
PAYLOAD_CMS_HOST=127.0.0.1
PAYLOAD_CMS_PORT=5080
PAYLOAD_CMS_PUBLIC_URL=http://127.0.0.1:5080
PAYLOAD_CMS_DATABASE_URL=
PAYLOAD_CMS_SECRET=
PAYLOAD_CMS_PREVIEW_SECRET=
PAYLOAD_CMS_CRON_SECRET=

PAYLOAD_ECOMMERCE_ENABLED=false
PAYLOAD_ECOMMERCE_HOST=127.0.0.1
PAYLOAD_ECOMMERCE_PORT=5085
PAYLOAD_ECOMMERCE_PUBLIC_URL=http://127.0.0.1:5085
PAYLOAD_ECOMMERCE_DATABASE_URL=
PAYLOAD_ECOMMERCE_SECRET=
PAYLOAD_ECOMMERCE_PREVIEW_SECRET=
PAYLOAD_ECOMMERCE_STRIPE_SECRET_KEY=
PAYLOAD_ECOMMERCE_STRIPE_PUBLISHABLE_KEY=
PAYLOAD_ECOMMERCE_STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# S3 (optional)
# -----------------------------------------------------------------------------
DJANGO_USE_S3_STORAGE=false
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_DEFAULT_ACL=private
AWS_QUERYSTRING_AUTH=true

# -----------------------------------------------------------------------------
# Sentry (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0

# -----------------------------------------------------------------------------
# Production-only required variables (must be set when DJANGO_DEBUG=false)
# -----------------------------------------------------------------------------
# DJANGO_SECRET_KEY
# DJANGO_ALLOWED_HOSTS
# DJANGO_CORS_ALLOWED_ORIGINS
# DJANGO_CSRF_TRUSTED_ORIGINS
# DJANGO_DB_ENGINE (non-sqlite)
# DJANGO_DB_NAME
# DJANGO_DB_USER
# DJANGO_DB_PASSWORD
# DJANGO_CACHE_URL (redis:// or rediss://)
# DJANGO_METRICS_AUTH_TOKEN (>=24 chars)
# DJANGO_AUTH_MAGIC_LOGIN_ENABLED=false
# DJANGO_ENABLE_ADMIN=false (recommended unless you intentionally expose /admin)
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS>=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# DJANGO_SECURE_HSTS_PRELOAD=true
# DJANGO_X_FRAME_OPTIONS=DENY
