[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
django = "<6.1,>=5.1"
djangorestframework = "<3.17,>=3.15"
django-cors-headers = "<5.1,>=4.6"
argon2-cffi = "<26.0,>=23.1"
gunicorn = "<24.0,>=23.0"
psycopg = {extras = ["binary"], version = "<3.3,>=3.2"}
psycopg2-binary = "*"
redis = "<6.0,>=5.0"
celery = "<6.0,>=5.3.4"
openai = "<2.0,>=1.109"
stripe = "<12.0,>=7.0"
boto3 = "<2.0,>=1.35"
django-storages = "<2.0,>=1.14"
meilisearch = "<0.35,>=0.34"
pluggy = "<2.0,>=1.5"
sentry-sdk = {extras = ["django"], version = "<3.0,>=2.0"}

[dev-packages]
pre-commit = "<4.0,>=3.6"

[requires]
python_version = "3.14"

[scripts]
serve = "python manage.py runserver 127.0.0.1:8000 --noreload"
migrate = "python manage.py migrate"
makemigrations = "python manage.py makemigrations builder"
check = "python manage.py check"
test = "python manage.py test builder"
