[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
django = "<6.1,>=5.1"
djangorestframework = "<3.17,>=3.15"
django-cors-headers = "<5.1,>=4.6"
gunicorn = "<24.0,>=23.0"
psycopg = {extras = ["binary"], version = "<3.3,>=3.2"}

[dev-packages]

[requires]
python_version = "3.14"

[scripts]
serve = "python manage.py runserver 127.0.0.1:8000 --noreload"
migrate = "python manage.py migrate"
makemigrations = "python manage.py makemigrations builder"
check = "python manage.py check"
test = "python manage.py test builder"
