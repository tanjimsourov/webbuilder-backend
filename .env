DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-64-char-random
DJANGO_ALLOWED_HOSTS=webbuilderapi.husmerk.com,127.0.0.1,localhost,web-builder.husmerk.com
DJANGO_CORS_ALLOWED_ORIGINS=https://smc-web-builder.husmerk.com,https://admin-web-builder.husmerk.com,https://web-builder.husmerk.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://smc-web-builder.husmerk.com,https://admin-web-builder.husmerk.com,https://web-builder.husmerk.com
DJANGO_LOG_LEVEL=INFO

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=smc_web_builder
DJANGO_DB_USER=smc_web_user
DJANGO_DB_PASSWORD=choose-a-strong-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=60

DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SESSION_COOKIE_SAMESITE=Strict
DJANGO_CSRF_COOKIE_SAMESITE=Strict

DJANGO_THROTTLE_ANON=60/hour
DJANGO_THROTTLE_USER=500/hour
DJANGO_THROTTLE_BURST=40/minute
DJANGO_THROTTLE_PUBLIC_FORM=30/hour
DJANGO_THROTTLE_PUBLIC_COMMENT=20/hour
DJANGO_THROTTLE_PUBLIC_CHECKOUT=60/hour
DJANGO_THROTTLE_WEBHOOK=1000/minute

DJANGO_MAX_UPLOAD_SIZE=10485760
DJANGO_MAX_IMAGE_SIZE=5242880
DJANGO_MAX_VIDEO_SIZE=104857600
DJANGO_MAX_DOCUMENT_SIZE=20971520

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.mailgun.org
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=postmaster@smtp.mailgun.org
DJANGO_EMAIL_HOST_PASSWORD=replace-with-real
DJANGO_DEFAULT_FROM_EMAIL=studio@smcwebbuilder.com

STRIPE_SECRET_KEY=sk_live_change
STRIPE_PUBLISHABLE_KEY=pk_live_change
STRIPE_WEBHOOK_SECRET=whsec_change

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Open-source AI alternatives (HuggingFace-hosted inference or local models)
AI_PROVIDER=open_source
AI_ENDPOINT_URL=http://127.0.0.1:8600/v1
AI_API_KEY=replace-with-local-token
AI_MODEL=writers/phi3.5-mini-instruct

LIBRECRAWL_ENABLED=true
